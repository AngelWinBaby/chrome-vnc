{
  "name": "Chrome Remote Desktop",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "forwardPorts": [6080, 22],
  "portsAttributes": {
    "6080": { "label": "noVNC" },
    "22": { "label": "SSH" }
  },
  "postCreateCommand": "bash /workspace/setup.sh && nohup bash /workspace/start.sh &",
  "customizations": { "vscode": { "extensions": [] } }
}
